{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(pip *)",
      "Bash(uv *)",
      "Bash(python *)",
      "Bash(pytest *)",
      "Bash(ruff *)",
      "Bash(ollama *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(curl *)",
      "Bash(env)",
      "Bash(pwd)",
      "Bash(which *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf .git)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "ruff format $FILE_PATH 2>/dev/null && ruff check --fix $FILE_PATH 2>/dev/null || true",
        "description": "Auto-format and lint-fix after edits"
      }
    ]
  }
}
