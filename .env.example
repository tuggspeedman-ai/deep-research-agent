# LLM — use "provider:model" format
# Local (Ollama):
MODEL=ollama:gemma4:26b
SUMMARIZER_MODEL=ollama:gemma4:e4b
# Cloud examples (uncomment one):
# MODEL=openai:gpt-5.4-mini
# MODEL=anthropic:claude-sonnet-4-6
# MODEL=google_genai:gemini-2.5-flash

# Ollama (only needed for local models)
OLLAMA_BASE_URL=http://localhost:11434

# Cloud provider API keys (set the one matching your MODEL)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Tavily (web search)
TAVILY_API_KEY=

# LangSmith (optional — for tracing/observability)
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=deep-research-agent
